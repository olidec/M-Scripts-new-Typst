{
  "files.associations": {
    "*.typ": "typst"
  },
  "files.exclude": {
    "**/_wrapper-*.typ": true
  },
  "files.watcherExclude": {
    "**/dist/**": true,
    "**/_wrapper-*.typ": true
  },
  "search.exclude": {
    "**/dist/**": true
  },
  "editor.rulers": [80],
  "[typst]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  }
}
